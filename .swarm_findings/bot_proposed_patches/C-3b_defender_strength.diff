+-- -- defenderStrength local replica (for formula-swap testing) -----------
+--
+-- Mirrors defenderStrength() from Bot.lua so the test can inject it into
+-- PickDouble without patching production code.  The test overrides
+-- Bot.PickDouble locally via a wrapper below.
+local function defenderStrengthLocal(hand, contract)
+    if contract.type == K.BID_SUN then
+        local s = 0
+        for _, card in ipairs(hand) do
+            local r = C.Rank(card)
+            if     r == "A" then s = s + 11
+            elseif r == "T" then s = s + 10
+            elseif r == "K" then s = s + 4
+            elseif r == "Q" then s = s + 3
+            elseif r == "J" then s = s + 2 end
+        end
+        return s + 10
+    end
+
+    local trump = contract.trump
+    local ownTrump = 0
+    if trump then
+        -- Replicate suitStrengthAsTrump at basic tier.
+        local strength, count = 0, 0
+        local hasJ, has9 = false, false
+        for _, card in ipairs(hand) do
+            if C.Suit(card) == trump then
+                count = count + 1
+                local r = C.Rank(card)
+                if     r == "J" then hasJ = true; strength = strength + 20
+                elseif r == "9" then has9 = true; strength = strength + 14
+                elseif r == "A" then strength = strength + 11
+                elseif r == "T" then strength = strength + 10
+                elseif r == "K" then strength = strength + 4
+                elseif r == "Q" then strength = strength + 3
+                elseif r == "8" then strength = strength + 2
+                elseif r == "7" then strength = strength + 2 end
+            end
+        end
+        strength = strength + math.max(0, count - 2) * 5
+        if hasJ and has9 then strength = strength + 10 end  -- basic-tier synergy
+        ownTrump = strength
+    end
+
+    local suitCount = { S = 0, H = 0, D = 0, C = 0 }
+    local sideAces  = 0
+    for _, card in ipairs(hand) do
+        local su = C.Suit(card)
+        suitCount[su] = suitCount[su] + 1
+        if C.Rank(card) == "A" and su ~= trump then
+            sideAces = sideAces + 1
+        end
+    end
+    local voids = 0
+    for _, su in ipairs(K.SUITS) do
+        if su ~= trump and suitCount[su] == 0 then
+            voids = voids + 1
+        end
+    end
+
+    local aceBonus  = math.max(0, sideAces - 1) * 8
+    local voidBonus = voids * 5
+    local BIDDER_MIN_TRUMP = 42
+    return ownTrump + voidBonus + aceBonus - BIDDER_MIN_TRUMP
+end
+
+-- Run the C-3b defenderStrength formula with a given threshold.
+-- Shares the same jitter-pin mechanism as pickDoubleAtTH.
+local function pickDoubleDefStrAtTH(hands, contract, defSeat, th)
+    local savedTH = K.BOT_BEL_TH
+    K.BOT_BEL_TH = th
+    math.random = function(a, b)
+        if a == -10 and b == 10 then return 0 end
+        return origRandom(a, b)
+    end
+    freshState()
+    S.s.isHost = true
+    S.s.contract = contract
+    S.s.hostHands = copyHands(hands)
+    S.s.bids = {}
+    S.s.cumulative = { A = 0, B = 0 }
+    S.s.target = 152
+    WHEREDNGNDB.advancedBots    = false
+    WHEREDNGNDB.m3lmBots        = false
+    WHEREDNGNDB.fzlokyBots      = false
+    WHEREDNGNDB.saudiMasterBots = false
+    if Bot.ResetStyle then Bot.ResetStyle() end
+
+    -- Compute strength using the C-3b formula directly.
+    local strength = defenderStrengthLocal(hands[defSeat], contract)
+    local urgency  = 0   -- urgency is 0 (fresh state, no bids/score)
+    local jth      = th - urgency   -- jitter already pinned to 0
+    local yes      = (strength >= jth)
+
+    K.BOT_BEL_TH = savedTH
+    math.random = origRandom
+    return yes
+end
+
