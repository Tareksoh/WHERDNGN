+-- Defender-perspective strength for the Bel decision (C-3 proper fix).
+--
+-- Replaces the old "sunStrength + suitStrengthAsTrump" formula which
+-- treated both teams symmetrically and produced 45-70% precision at any
+-- threshold while recall collapsed (247/268 winnable Bels missed at TH=70).
+--
+-- Saudi-rule Bel viability: defender holds J+9 of trump OR 3+ side-suit Aces.
+-- This function encodes three defender edges the old formula ignored:
+--   1. Void suits: each void is a ruffing lane worth ~5 extra strength.
+--   2. Side-suit Aces beyond the first: each extra Ace is ~8 strength
+--      (first Ace is already captured by sunStrength; only marginal Aces
+--      beyond the first provide incremental defensive value).
+--   3. Bidder's claimed trump strength: a Hokm bid guarantees the bidder
+--      holds at least J+9 of trump (≥42 trump points). Subtracting this
+--      gives a relative defender advantage rather than an absolute count.
+--
+-- Sun contracts fall back to the original path (sunStrength + 10 bias)
+-- because Sun has no trump and therefore no ruffing or trump-control axis.
+--
+-- Returns a scalar on the same scale as the old formula so BOT_BEL_TH
+-- is still the threshold (lower TH=60 is appropriate for this formula).
+local function defenderStrength(hand, contract, seat)
+    -- Sun: no trump axis; use the original calculation unchanged.
+    if contract.type == K.BID_SUN then
+        return sunStrength(hand) + 10
+    end
+
+    -- Hokm: trump-control component (same weights as suitStrengthAsTrump).
+    local trump = contract.trump
+    local ownTrump = 0
+    if trump then
+        ownTrump = suitStrengthAsTrump(hand, trump)
+    end
+
+    -- Void-suit ruffing potential: each suit with zero cards is +5.
+    local suitCount = { S = 0, H = 0, D = 0, C = 0 }
+    local sideAces  = 0
+    for _, card in ipairs(hand) do
+        local su = C.Suit(card)
+        suitCount[su] = suitCount[su] + 1
+        if C.Rank(card) == "A" and su ~= trump then
+            sideAces = sideAces + 1
+        end
+    end
+    local voids = 0
+    for _, su in ipairs(K.SUITS) do
+        if su ~= trump and suitCount[su] == 0 then
+            voids = voids + 1
+        end
+    end
+
+    -- Side-suit Aces beyond the first add +8 each (first is already
+    -- priced into the general hand value; only marginal Aces matter).
+    local aceBonus  = math.max(0, sideAces - 1) * 8
+    local voidBonus = voids * 5
+
+    -- Bidder's claimed trump strength: a Hokm bid guarantees J+9 of trump.
+    -- The minimum guaranteed trump score for the bidder is 20 (J) + 14 (9)
+    -- + 8 (J+9 synergy bonus at basic tier) = 42.
+    local BIDDER_MIN_TRUMP = 42
+
+    -- Defender score = own trump + ruffing lanes + extra Aces
+    --                  - bidder's guaranteed trump floor.
+    -- Negative values mean the bidder's trump control dominates; the
+    -- jitter + threshold gate will keep those from firing.
+    return ownTrump + voidBonus + aceBonus - BIDDER_MIN_TRUMP
+end
+
