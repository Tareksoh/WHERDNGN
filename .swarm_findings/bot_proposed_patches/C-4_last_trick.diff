+-- Return the card from `cards` with the highest face-value point total,
+-- tie-broken by TrickRank (so among equals we take the stronger card).
+-- Used for trick-8 "cash maximum points" decisions.
+local function highestByFaceValue(cards, contract)
+    local best, bestPts, bestR = cards[1], -1, -1
+    for _, c in ipairs(cards) do
+        local pts = C.PointValue(c, contract)
+        local r   = C.TrickRank(c, contract)
+        if pts > bestPts or (pts == bestPts and r > bestR) then
+            best, bestPts, bestR = c, pts, r
+        end
+    end
+    return best
+end
