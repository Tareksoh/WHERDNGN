+-- tests/test_c4_last_trick.lua
+--
+-- Simulation test for C-4: trick-8 last-trick bonus targeting.
+--
+-- Methodology:
+--   Run 1 000 synthetic hands.  In each hand we fast-play tricks 1-7 with
+--   random-legal moves (to reach a realistic trick-8 state), then compare
+--   the trick-8 winner under the PATCHED pickFollow/pickLead vs the BASELINE
+--   (lowestByRank everywhere in trick 8).
+--
+--   "Trick-8 win" = the team that takes the last trick (earns LAST_TRICK_BONUS).
+--
+-- Expected: patched win-rate for the team leading trick 8 is meaningfully
+-- higher than baseline (≥ +3 pp at α = 0.05).
+--
+-- Run with: lua tests/test_c4_last_trick.lua
+
+unpack = unpack or table.unpack
+
+-- -- Locate addon root -------------------------------------------------------
+local function addonRoot()
+    if WHEREDNGN_TESTS_ROOT then return WHEREDNGN_TESTS_ROOT end
+    local src = debug.getinfo(1, "S").source
+    if src:sub(1, 1) ~= "@" then
+        error("set WHEREDNGN_TESTS_ROOT before running")
+    end
+    return (src:sub(2):gsub("[/\\]tests[/\\][^/\\]+$", ""))
+end
+local ROOT = addonRoot()
+
+-- -- WoW globals stubs -------------------------------------------------------
+local fakeNow = 3000000.0
+GetTime = function() fakeNow = fakeNow + 0.001; return fakeNow end
+C_Timer = {
+    NewTicker = function() return { Cancel = function() end } end,
+    NewTimer  = function() return { Cancel = function() end } end,
+    After     = function() end,
+}
+GetUnitName  = function() return "T" end
+UnitName     = function() return "T" end
+WHEREDNGNDB  = {}
+SendChatMessage = function() end
+C_ChatInfo = {
+    RegisterAddonMessagePrefix = function() return true end,
+    SendAddonMessage = function() end,
+}
+CreateFrame = function()
+    return {
+        SetScript = function() end, RegisterEvent = function() end,
+        UnregisterEvent = function() end,
+        Hide = function() end, Show = function() end,
+    }
+end
+WHEREDNGN = WHEREDNGN or {}
+WHEREDNGN.Sound = { Cue = function() end, ArmCue = function() end }
+WHEREDNGN.Log   = {
+    Debug = function() end, Info = function() end, Warn = function() end,
+    Error = function() end, Clear = function() end, Dump = function() end,
+}
+WHEREDNGN.UI = {
+    Refresh = function() end, Show = function() end,
+    Hide = function() end, Toggle = function() end,
+}
+
+-- -- Load addon files --------------------------------------------------------
+local function load(rel)
+    local path = (ROOT .. "/" .. rel):gsub("\\", "/")
+    local chunk, err = loadfile(path)
+    if not chunk then error("failed to load " .. rel .. ": " .. tostring(err)) end
+    chunk()
+end
+load("Constants.lua")
+load("Cards.lua")
+load("Rules.lua")
+load("State.lua")
+load("Bot.lua")
+
+local K   = WHEREDNGN.K
+local C   = WHEREDNGN.Cards
+local R   = WHEREDNGN.Rules
+local S   = WHEREDNGN.State
+local Bot = WHEREDNGN.Bot
+
+math.randomseed(20260504)
+
+-- -- Helpers -----------------------------------------------------------------
+
+local function freshRound()
+    local s = S.s
+    s.phase   = K.PHASE_PLAY
+    s.isHost  = true
+    s.gameID  = "test"
+    s.tricks  = {}
+    s.trick   = nil
+    s.playedCardsThisRound = {}
+    s.akaCalled = nil
+    if Bot.ResetMemory then Bot.ResetMemory() end
+end
+
+-- Deal 32 cards to 4 seats.
+local function deal(seed)
+    local deck = {}
+    for _, su in ipairs(K.SUITS) do
+        for _, r in ipairs(K.RANKS) do deck[#deck + 1] = r .. su end
+    end
+    C.Shuffle(deck, seed)
+    local hands = {}
+    local idx = 1
+    for seat = 1, 4 do
+        hands[seat] = {}
+        for _ = 1, 8 do
+            hands[seat][#hands[seat] + 1] = deck[idx]; idx = idx + 1
+        end
+    end
+    return hands
+end
+
+-- Random legal play for seat (used to advance tricks 1-7 neutrally).
+local function randomLegalPlay(seat, hand, trick, contract)
+    local legal = {}
+    for _, c in ipairs(hand) do
+        if R.IsLegalPlay(c, hand, trick, contract, seat) then
+            legal[#legal + 1] = c
+        end
+    end
+    if #legal == 0 then return hand[1] end
+    return legal[math.random(#legal)]
+end
+
+-- Remove a card from a hand table in-place.
+local function removeCard(hand, card)
+    for i, c in ipairs(hand) do
+        if c == card then table.remove(hand, i); return end
+    end
+end
+
+-- Play tricks 1..(trickN-1) with random-legal moves; return the leader for
+-- trick `trickN` and the residual hands.
+local function advanceToTrick(hands, contract, trickN)
+    local h = {}
+    for seat = 1, 4 do
+        h[seat] = {}
+        for _, c in ipairs(hands[seat]) do h[seat][#h[seat] + 1] = c end
+    end
+    S.s.hostHands = h
+
+    local leader = contract.bidder  -- bidder leads trick 1 in Hokm
+    for t = 1, trickN - 1 do
+        S.s.trick = { leadSuit = nil, plays = {} }
+        local seat = leader
+        for _ = 1, 4 do
+            local card = randomLegalPlay(seat, h[seat], S.s.trick, contract)
+            removeCard(h[seat], card)
+            S.s.trick.plays[#S.s.trick.plays + 1] = { seat = seat, card = card }
+            if #S.s.trick.plays == 1 then
+                S.s.trick.leadSuit = C.Suit(card)
+            end
+            seat = (seat % 4) + 1
+        end
+        local winner = R.TrickWinner(S.s.trick, contract)
+        local pts    = R.TrickPoints(S.s.trick, contract)
+        S.ApplyTrickEnd(winner, pts)
+        leader = winner
+    end
+    return leader, h
+end
+
+-- Play a single trick using Bot.PickPlay for each seat; return the winner.
+local function playOneTrick(h, contract, leader, useBotLogic)
+    S.s.trick = { leadSuit = nil, plays = {} }
+    S.s.hostHands = h
+    local seat = leader
+    for _ = 1, 4 do
+        local card
+        if useBotLogic then
+            card = Bot.PickPlay(seat)
+        else
+            card = randomLegalPlay(seat, h[seat], S.s.trick, contract)
+        end
+        if not card then
+            error(("playOneTrick: seat %d returned nil"):format(seat))
+        end
+        removeCard(h[seat], card)
+        S.s.trick.plays[#S.s.trick.plays + 1] = { seat = seat, card = card }
+        if #S.s.trick.plays == 1 then
+            S.s.trick.leadSuit = C.Suit(card)
+        end
+        seat = (seat % 4) + 1
+    end
+    return R.TrickWinner(S.s.trick, contract)
+end
+
+-- -- Simulation -------------------------------------------------------------
+
+local N = 1000
+WHEREDNGNDB.advancedBots    = true   -- exercise all branches including C-4
+WHEREDNGNDB.m3lmBots        = false
+WHEREDNGNDB.fzlokyBots      = false
+WHEREDNGNDB.saudiMasterBots = false
+
+local patchedLeaderWins   = 0  -- trick-8 leader's team wins with bot logic
+local baselineLeaderWins  = 0  -- trick-8 leader's team wins with random logic
+local totalHands          = 0
+
+for i = 1, N do
+    -- Build a Hokm contract with a reasonable trump (highest-scoring suit
+    -- for seat 1 so the hand isn't degenerate).
+    local hands = deal(i)
+    local contract = { type = K.BID_HOKM, trump = "S", bidder = 1 }
+
+    -- --- PATCHED run ---
+    freshRound()
+    S.s.contract = contract
+    local leader7p, hp = advanceToTrick(hands, contract, 8)
+    local winnerP = playOneTrick(hp, contract, leader7p, true)
+    local leaderTeam = R.TeamOf(leader7p)
+    if R.TeamOf(winnerP) == leaderTeam then patchedLeaderWins = patchedLeaderWins + 1 end
+
+    -- --- BASELINE run (random legal plays for trick 8) ---
+    freshRound()
+    S.s.contract = contract
+    local leader7b, hb = advanceToTrick(hands, contract, 8)
+    local winnerB = playOneTrick(hb, contract, leader7b, false)
+    if R.TeamOf(winnerB) == R.TeamOf(leader7b) then baselineLeaderWins = baselineLeaderWins + 1 end
+
+    totalHands = totalHands + 1
+end
+
+local patchedRate  = patchedLeaderWins  / totalHands
+local baselineRate = baselineLeaderWins / totalHands
+local delta        = patchedRate - baselineRate
+
+print(string.format(
+    "C-4 simulation  N=%d\n"
+    .. "  patched  trick-8 leader-team win-rate : %.1f%%\n"
+    .. "  baseline trick-8 leader-team win-rate : %.1f%%  (random legal plays)\n"
+    .. "  delta                                 : %+.1f pp\n"
+    .. "  PASS: %s  (threshold: delta > 3 pp)",
+    totalHands,
+    patchedRate  * 100,
+    baselineRate * 100,
+    delta        * 100,
+    (delta > 0.03) and "YES" or "NO"
+))
+
+assert(delta > 0.03,
+    ("C-4: trick-8 win-rate improvement %.1f pp is below 3 pp threshold"):format(delta * 100))
+
+print("\nC-4 test PASSED.")
