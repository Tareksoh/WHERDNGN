+-- Helper: desire map for defender seats in a Hokm contract.
+--
+-- Defenders cluster non-trump Aces and Kings because the bidder committed
+-- to trump strength — side-suit power cards tend to live in non-bidder hands.
+--
+-- Three bias tiers (weights feed the `weight > 0` branch in the pool loop):
+--   desire["A"..s] = 8   non-trump Ace  (strong clustering)
+--   desire["K"..s] = 4   non-trump King (lighter secondary bias)
+--   desire[s]      = true long-suit incentive: activates the existing
+--                          `desire[C.Suit(c)] and 20` fallback for every
+--                          other card in the suit, biasing 4+ length onto
+--                          defenders.  The card-level A/K entries above take
+--                          precedence (desire[card] is checked first in the
+--                          pool loop), so Kings and Aces use their own weight
+--                          rather than the suit-level 20.
+--
+-- Returns {} for SUN contracts (no trump, side-suit distribution is uniform).
+local function getDefenderCards(contract)
+    local desire = {}
+    if not contract or contract.type ~= K.BID_HOKM or not contract.trump then
+        return desire
+    end
+    local t = contract.trump
+    for _, s in ipairs(K.SUITS) do
+        if s ~= t then
+            desire["A"..s] = 8    -- non-trump Ace: weight 8
+            desire["K"..s] = 4    -- non-trump King: weight 4
+            desire[s]      = true -- long-suit incentive for remaining cards
+        end
+    end
+    return desire
+end
+
 -- Helper: returns true if Saudi-Master tier is active.
 function BM.IsActive()
