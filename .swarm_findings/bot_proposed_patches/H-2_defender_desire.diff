-                local desire = (s == bidder) and strong or {}
+                --
+                -- H-2: role-based desire dispatch for Hokm contracts.
+                -- Role is determined by absolute team comparison so that BOTH
+                -- defender seats get the same bias regardless of which seat is
+                -- calling the sampler (avoids seat-index asymmetry).
+                --
+                --   bidder   -> strong cards (J/9/A of trump + side Aces at 15)
