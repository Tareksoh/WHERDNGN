+-- ---------------------------------------------------------------------
+-- C-2: SWA initiation
+-- ---------------------------------------------------------------------
+-- Bot.PickSWA(seat) → true when the bot holds an unbeatable position
+-- and should claim all remaining tricks via SWA (سوا) immediately.
+--
+-- RATIONALE (110 words):
+-- Bots never called SWA. In Saudi play, SWA wins are common when a
+-- player holds unbeatable cards in the last 3-4 tricks. Without this,
+-- bots silently play out guaranteed-win positions trick-by-trick,
+-- wasting time and looking distinctly non-human. The fix gates on
+-- Bot.IsAdvanced() (Advanced-tier bot minimum), phase PHASE_PLAY,
+-- hand-size ≤ 4 (Saudi convention), and delegates the actual
+-- correctness check to R.IsValidSWA — the existing full-minimax
+-- validator. A fast early-exit skips IsValidSWA entirely when the
+-- hand has more than 4 cards, keeping the per-turn overhead negligible.
+-- Saudi rule: ≤ 3 cards = instant claim; 4 cards = 5-sec permission
+-- window. That split is handled by the existing Net.lua SWA dispatch;
+-- PickSWA just returns true/false.
+--
+-- TEST COVERAGE: see tests/test_pickswa.lua (added below).
+
+function Bot.PickSWA(seat)
+    -- Gate 1: Advanced-or-higher tier only.
+    if not Bot.IsAdvanced() then return false end
+    -- Gate 2: play phase only.
+    if S.s.phase ~= K.PHASE_PLAY then return false end
+    -- Gate 3: use the host's authoritative hand record.
+    local hand = S.s.hostHands and S.s.hostHands[seat]
+    if not hand or #hand == 0 then return false end
+    -- Gate 4: Saudi convention — SWA only viable with ≤ 4 cards left.
+    if #hand > 4 then return false end
+    -- Gate 5: contract must exist for IsValidSWA.
+    local contract = S.s.contract
+    if not contract then return false end
+    -- Reconstruct the trickState snapshot (mirrors HostResolveSWA).
+    local trickPlays = (S.s.trick and S.s.trick.plays) or {}
+    local trickState = {
+        leadSuit = S.s.trick and S.s.trick.leadSuit,
+        leader   = (#trickPlays > 0) and trickPlays[1].seat
+                   or S.s.turn or seat,
+        plays    = trickPlays,
+    }
+    -- Snapshot all four hands for the minimax (same shape as
+    -- HostResolveSWA so the validator sees the real remaining deck).
+    local hands = {}
+    for s2 = 1, 4 do
+        hands[s2] = (S.s.hostHands and S.s.hostHands[s2]) or {}
+    end
+    -- Delegate correctness entirely to the minimax validator.
+    -- No extra heuristic: if R.IsValidSWA says yes, it IS unbeatable.
+    return R.IsValidSWA(seat, hands, contract, trickState) == true
+end

