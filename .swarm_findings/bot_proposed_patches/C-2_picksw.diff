+-- tests/test_pickswa.lua
+--
+-- Unit tests for Bot.PickSWA (C-2).
+--
+-- Scenarios exercised:
+--   A. Gate checks: wrong phase, too many cards, non-Advanced tier all
+--      return false without calling IsValidSWA.
+--   B. Unbeatable single-suit run: seat 1 holds A♠ K♠ Q♠ (3 cards),
+--      opponents have exhausted their spades — PickSWA must return true.
+--   C. Forced-loss position: seat 1 holds only 7♠, opponent holds A♠ —
+--      PickSWA must return false.
+--   D. Boundary: exactly 4 cards held, valid SWA → true.
+--   E. Boundary: 5 cards held → false (gate fires before IsValidSWA).
+--
+-- Run: lua tests/test_pickswa.lua
+--      or via python tests/run.py (after adding this file to the runner).
+
+unpack = unpack or table.unpack
+
+local function addonRoot()
+    if WHEREDNGN_TESTS_ROOT then return WHEREDNGN_TESTS_ROOT end
+    local src = debug.getinfo(1, "S").source
+    if src:sub(1, 1) ~= "@" then
+        error("set WHEREDNGN_TESTS_ROOT before running")
+    end
+    return (src:sub(2):gsub("[/\\]tests[/\\][^/\\]+$", ""))
+end
+local ROOT = addonRoot()
+
+-- -- WoW globals stubs ---------------------------------------------------
+local fakeNow = 1000000.0
+GetTime = function() fakeNow = fakeNow + 0.001; return fakeNow end
+C_Timer = {
+    After     = function() end,
+    NewTicker = function() return { Cancel = function() end } end,
+    NewTimer  = function() return { Cancel = function() end } end,
+}
+GetUnitName = function() return "TestPlayer" end
+UnitName    = function() return "TestPlayer" end
+WHEREDNGNDB = { advancedBots = true }
+SendChatMessage   = function() end
+C_ChatInfo = {
+    RegisterAddonMessagePrefix = function() return true end,
+    SendAddonMessage = function() end,
+}
+CreateFrame = function()
+    return {
+        SetScript      = function() end,
+        RegisterEvent  = function() end,
+        UnregisterEvent= function() end,
+        Hide = function() end, Show = function() end,
+    }
+end
+
+WHEREDNGN = WHEREDNGN or {}
+WHEREDNGN.Sound = { Cue = function() end, ArmCue = function() end }
+WHEREDNGN.Log   = {
+    Debug = function() end, Info = function() end,
+    Warn  = function() end, Error= function() end,
+    Clear = function() end, Dump = function() end,
+}
+WHEREDNGN.UI = {
+    Refresh = function() end, Show = function() end,
+    Hide    = function() end, Toggle = function() end,
+}
+
+-- -- Load modules ---------------------------------------------------------
+local function load(rel)
+    local path = (ROOT .. "/" .. rel):gsub("\\", "/")
+    local chunk, err = loadfile(path)
+    if not chunk then error("failed to load " .. rel .. ": " .. tostring(err)) end
+    chunk()
+end
+load("Constants.lua")
+load("Cards.lua")
+load("Rules.lua")
+load("State.lua")
+load("Bot.lua")
+
+local K   = WHEREDNGN.K
+local C   = WHEREDNGN.Cards
+local R   = WHEREDNGN.Rules
+local S   = WHEREDNGN.State
+local Bot = WHEREDNGN.Bot
+
+math.randomseed(20260503)
+
+-- -- Tiny test framework --------------------------------------------------
+local pass, fail = 0, 0
+local failures   = {}
+local VERBOSE    = (TEST_VERBOSE == true)
+
+local function assertEq(actual, expected, name)
+    if actual == expected then
+        pass = pass + 1
+        if VERBOSE then print(("  PASS  %s"):format(name)) end
+    else
+        fail = fail + 1
+        local msg = ("FAIL  %s\n        expected: %s\n        actual:   %s")
+                       :format(name, tostring(expected), tostring(actual))
+        failures[#failures + 1] = msg
+        print("  " .. msg)
+    end
+end
+local function assertTrue(v, n)  assertEq(not not v, true,  n) end
+local function assertFalse(v, n) assertEq(not not v, false, n) end
+local function section(label) print(""); print("== " .. label .. " ==") end
+
+-- -- Helpers --------------------------------------------------------------
+
+-- Minimal state reset sufficient for PickSWA.
+local function freshState()
+    local s = S.s
+    s.phase     = K.PHASE_IDLE
+    s.isHost    = true
+    s.contract  = nil
+    s.hostHands = nil
+    s.trick     = nil
+    s.tricks    = {}
+    s.turn      = 1
+    s.turnKind  = "play"
+    s.paused    = false
+    s.swaRequest= nil
+    s.swaResult = nil
+    s.playedCardsThisRound = {}
+    s.seats     = { [1]=nil, [2]=nil, [3]=nil, [4]=nil }
+    s.meldsByTeam  = { A={}, B={} }
+    s.meldsDeclared= {}
+end
+
+local function sunContract(bidder)
+    return { type = K.BID_SUN, bidder = bidder or 1 }
+end
+
+-- =====================================================================
+-- A. Gate checks
+-- =====================================================================
+section("A. Gate checks")
+
+freshState()
+S.s.phase     = K.PHASE_PLAY
+S.s.contract  = sunContract(1)
+S.s.hostHands = { [1]={"AS","KS","QS"}, [2]={}, [3]={}, [4]={} }
+-- Non-advanced tier: must return false regardless of hand strength.
+WHEREDNGNDB = {}   -- advancedBots, m3lmBots, etc. all nil/false
+assertFalse(Bot.PickSWA(1), "gate: non-Advanced tier → false")
+WHEREDNGNDB = { advancedBots = true }  -- restore for remaining tests
+
+freshState()
+S.s.phase     = K.PHASE_SCORE   -- wrong phase
+S.s.contract  = sunContract(1)
+S.s.hostHands = { [1]={"AS","KS","QS"}, [2]={}, [3]={}, [4]={} }
+assertFalse(Bot.PickSWA(1), "gate: wrong phase → false")
+
+freshState()
+S.s.phase     = K.PHASE_PLAY
+S.s.contract  = sunContract(1)
+-- 5-card hand: over the 4-card threshold.
+S.s.hostHands = { [1]={"AS","KS","QS","JS","TS"}, [2]={}, [3]={}, [4]={} }
+assertFalse(Bot.PickSWA(1), "gate: 5-card hand → false")
+
+-- =====================================================================
+-- B. Contrived unbeatable single-suit run (the canonical C-2 scenario)
+-- Seat 1 holds A♠ K♠ Q♠.  No spades remain in any other hand.
+-- Opponents have zero cards (they have already played everything).
+-- In a SUN contract, A♠ → K♠ → Q♠ each wins their trick.
+-- R.IsValidSWA minimax must confirm; PickSWA must return true.
+-- =====================================================================
+section("B. Unbeatable single-suit run")
+
+freshState()
+S.s.phase     = K.PHASE_PLAY
+S.s.contract  = sunContract(1)
+-- Seat 1 holds the top three spades.  All other seats empty (they have
+-- played all their cards — late-game endgame).
+S.s.hostHands = {
+    [1] = { "AS", "KS", "QS" },
+    [2] = {},
+    [3] = {},
+    [4] = {},
+}
+-- No in-flight trick: seat 1 is about to lead.
+S.s.trick = { leadSuit = nil, plays = {} }
+S.s.turn  = 1
+-- Mark A♠ K♠ as already played by opponents so rank-order is correct.
+-- (With empty opp hands the minimax has no adversarial moves; it resolves
+-- immediately — every trick won by seat 1.)
+assertTrue(Bot.PickSWA(1), "unbeatable A+K+Q single suit: PickSWA → true")
+
+-- =====================================================================
+-- C. Forced-loss: seat 1 holds only 7♠; opponent holds A♠.
+-- =====================================================================
+section("C. Forced-loss position")
+
+freshState()
+S.s.phase     = K.PHASE_PLAY
+S.s.contract  = sunContract(2)  -- bidder is seat 2
+S.s.hostHands = {
+    [1] = { "7S" },
+    [2] = { "AS" },
+    [3] = {},
+    [4] = {},
+}
+S.s.trick = { leadSuit = nil, plays = {} }
+S.s.turn  = 1
+assertFalse(Bot.PickSWA(1), "forced-loss 7S vs AS: PickSWA → false")
+
+-- =====================================================================
+-- D. Boundary: exactly 4 cards, valid SWA (four top spades).
+-- =====================================================================
+section("D. Boundary: 4-card valid SWA")
+
+freshState()
+S.s.phase     = K.PHASE_PLAY
+S.s.contract  = sunContract(1)
+S.s.hostHands = {
+    [1] = { "AS", "KS", "QS", "JS" },
+    [2] = {},
+    [3] = {},
+    [4] = {},
+}
+S.s.trick = { leadSuit = nil, plays = {} }
+S.s.turn  = 1
+assertTrue(Bot.PickSWA(1), "boundary 4-card valid SWA → true")
+
+-- =====================================================================
+-- E. Boundary: 5 cards → fast-exit gate fires before IsValidSWA.
+-- =====================================================================
+section("E. Boundary: 5-card fast-exit")
+
+freshState()
+S.s.phase     = K.PHASE_PLAY
+S.s.contract  = sunContract(1)
+S.s.hostHands = {
+    [1] = { "AS", "KS", "QS", "JS", "TS" },
+    [2] = {},
+    [3] = {},
+    [4] = {},
+}
+S.s.trick = { leadSuit = nil, plays = {} }
+S.s.turn  = 1
+assertFalse(Bot.PickSWA(1), "boundary 5-card hand → false (gate)")
+
+-- =====================================================================
+-- Summary
+-- =====================================================================
+print("")
+print(("=== test_pickswa: %d passed, %d failed ==="):format(pass, fail))
+for _, m in ipairs(failures) do print(m) end
+if fail > 0 then os.exit(1) else os.exit(0) end
